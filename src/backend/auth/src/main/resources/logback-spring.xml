<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <springProperty scope="context" name="LOG_LEVEL" source="LOG_LEVEL" defaultValue="INFO"/>
  <property name="SERVICE_NAME" value="auth"/>

  <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
    <encoder>
      <pattern>{"time":"%d{yyyy-MM-dd'T'HH:mm:ss.SSSZ}","level":"%level","service":"${SERVICE_NAME}","request_id":"%X{request_id:-}","event":"%X{event:-}","method":"%X{method:-}","path":"%X{path:-}","status":"%X{status:-}","grpc_method":"%X{grpc_method:-}","grpc_code":"%X{grpc_code:-}","duration_ms":"%X{duration_ms:-}","error":"%X{error:-}","logger":"%logger{36}","msg":"%replace(%msg){'\"','\\\"'}"}%n</pattern>
    </encoder>
  </appender>

  <root level="${LOG_LEVEL}">
    <appender-ref ref="CONSOLE"/>
  </root>
</configuration>
