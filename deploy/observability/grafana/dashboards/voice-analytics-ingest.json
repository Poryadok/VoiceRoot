{
  "uid": "voice-analytics-ingest",
  "title": "Voice Analytics — Ingest",
  "tags": ["voice", "analytics", "ingest"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Ingest lag (p95 seconds)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(analytics_ingest_lag_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 lag"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Events ingested / sec",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(analytics_ingest_events_total[5m])",
          "legendFormat": "events/s"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "ClickHouse insert latency (p95)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.95, sum(rate(analytics_clickhouse_insert_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95 insert"
        }
      ]
    },
    {
      "id": 4,
      "type": "gauge",
      "title": "Buffer depth",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "refId": "A",
          "expr": "analytics_buffer_depth",
          "legendFormat": "pending"
        }
      ]
    }
  ]
}
