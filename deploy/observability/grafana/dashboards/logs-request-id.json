{
  "uid": "logs-request-id",
  "title": "Voice Logs \u2014 Request ID",
  "tags": [
    "voice",
    "logs"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "editable": true,
  "graphTooltip": 1,
  "links": [
    {
      "title": "Voice Overview",
      "url": "/d/voice-overview/voice-overview",
      "type": "link"
    }
  ],
  "templating": {
    "list": [
      {
        "name": "request_id",
        "type": "textbox",
        "label": "request_id",
        "description": "Paste X-Request-Id from Gateway response or client",
        "current": {
          "selected": false,
          "text": "",
          "value": ""
        },
        "options": [
          {
            "selected": true,
            "text": "",
            "value": ""
          }
        ]
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "Logs for request_id",
      "gridPos": {
        "h": 14,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "{namespace=\"voice-staging\"} | json | request_id=\"$request_id\""
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Event timeline",
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (event) (count_over_time({namespace=\"voice-staging\"} | json | request_id=\"$request_id\" [1m]))"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "wrapLogMessage": true,
        "sortOrder": "Descending"
      }
    }
  ]
}
