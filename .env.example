# Copy to .env for docker compose (do not commit .env).
# Values are dev-only defaults from docker-compose.yml.

# Cap parallel image builds (avoids proxy.golang.org TLS timeouts on slow networks).
COMPOSE_PARALLEL_LIMIT=4

POSTGRES_USER=voice
POSTGRES_PASSWORD=voice
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379

# Optional: docker compose --profile app (auth + gateway + Flutter web)
# AUTH is not published on the host; use gateway :8080 for /api/v1/auth/*
# GATEWAY_PORT=8080
# WEB_PORT=9080
# URL baked into the web image for browser -> gateway on the host (published port).
# VOICE_API_PUBLIC_URL=http://127.0.0.1:8080
# Browser-reachable LiveKit WS URL (voice JWT + GET .../token + web dart-define).
# VOICE_LIVEKIT_PUBLIC_URL=ws://127.0.0.1:7880

# --- Object storage: profile avatars (User) and chat attachments (File) ---
# Without *_R2_* vars, DM text and realtime chat work; avatar presign and file upload return FailedPrecondition.

# Local dev only: MinIO starts with `make compose-app-up` (--profile app). Not used on staging/prod.
# MINIO_PORT=9000
# MINIO_CONSOLE_PORT=9001
# MINIO_ROOT_USER=voice-minio
# MINIO_ROOT_PASSWORD=voice-minio-dev
# USER_R2_ENDPOINT=http://host.docker.internal:9000
# USER_R2_REGION=us-east-1
# USER_R2_ACCESS_KEY_ID=voice-minio
# USER_R2_SECRET_ACCESS_KEY=voice-minio-dev
# USER_R2_BUCKET=voice-dev-avatars
# USER_R2_PUBLIC_BASE_URL=http://127.0.0.1:9000/voice-dev-avatars
# FILE_R2_ENDPOINT=http://host.docker.internal:9000
# FILE_R2_REGION=us-east-1
# FILE_R2_ACCESS_KEY_ID=voice-minio
# FILE_R2_SECRET_ACCESS_KEY=voice-minio-dev
# FILE_R2_BUCKET=voice-dev-files

# Staging/prod: Cloudflare R2 (set in k8s secrets, not MinIO).
# USER_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# USER_R2_REGION=auto
# USER_R2_ACCESS_KEY_ID=
# USER_R2_SECRET_ACCESS_KEY=
# USER_R2_BUCKET=voice-dev-avatars
# USER_R2_PUBLIC_BASE_URL=https://cdn.example.com/avatars
# FILE_R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
# FILE_R2_REGION=auto
# FILE_R2_ACCESS_KEY_ID=
# FILE_R2_SECRET_ACCESS_KEY=
# FILE_R2_BUCKET=voice-dev-files

# gRPC bootstrap: max wait for upstream gRPC at service start (user, chat, messaging, file, bot, matchmaking).
# GRPC_DIAL_TIMEOUT=15s

# HTTP server and lifecycle timeouts (Go services; realtime defaults read/write to 0).
# HTTP_READ_HEADER_TIMEOUT=5s
# HTTP_READ_TIMEOUT=30s
# HTTP_WRITE_TIMEOUT=60s
# HTTP_IDLE_TIMEOUT=120s
# HTTP_SHUTDOWN_TIMEOUT=10s
# POSTGRES_CONNECT_TIMEOUT=15s

# --- Developer Portal OAuth (compose --profile app) ---
# Browser calls gateway; Auth issues authorization codes for the portal SPA.
# DEVELOPER_PORTAL_PORT=9082
# DEVELOPER_PORTAL_OAUTH_CLIENT_ID=voice-developer-portal
# DEVELOPER_PORTAL_OAUTH_CLIENT_SECRET=   # optional for PKCE public client
# DEVELOPER_PORTAL_OAUTH_REDIRECT_URIS=http://localhost:9082/callback,http://127.0.0.1:9082/callback
# VOICE_API_PUBLIC_URL=http://127.0.0.1:18080
# DEVELOPER_PORTAL_OAUTH_DISABLED=false   # set true to show paste-JWT fallback in portal

# Search service (compose profile app): PostgreSQL search_db + NATS indexers.
# SEARCH_GRPC_LISTEN=:9090
# SEARCH_INSTANCE_ID=local-dev
# USER_GRPC_ADDR=user:9090
# SPACE_GRPC_ADDR=space:9090

# Client version policy (Gateway GET /api/v1/version). JSON map per platform.
# GATEWAY_DATABASE_URL=postgres://voice:voice@localhost:5432/gateway_db?sslmode=disable
# GATEWAY_VERSION_CONFIGS_JSON={"windows":{"min_supported_version":"1.0.0","latest_version":"1.0.0","update_url":"https://updates.voice.example/windows/appcast.xml","release_notes":""},"android":{"min_supported_version":"1.0.0","latest_version":"1.0.0","update_url":"https://play.google.com/store/apps/details?id=voice.app.voice_frontend","release_notes":"","shorebird_patch":0},"ios":{"min_supported_version":"1.0.0","latest_version":"1.0.0","update_url":"https://apps.apple.com/app/id000000000","release_notes":"","shorebird_patch":0}}
